# Настройки для docker compose. Скопируй этот файл в .env и подставь свои значения:
#     copy .env.example .env      (Windows)
#     cp .env.example .env        (bash)
#
# Файл .env НЕ попадает в git (см. .gitignore) — в нём живут пароли и секреты.

# --- Секрет для подписи токенов входа ---
# ОБЯЗАТЕЛЬНО замени на длинную случайную строку. Сгенерировать можно так:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# Если поменяешь секрет у работающего портала — все войдут заново, это нормально.
JWT_SECRET=ЗАМЕНИ_МЕНЯ_на_длинную_случайную_строку

# --- База данных ---
POSTGRES_USER=dnd
POSTGRES_PASSWORD=ЗАМЕНИ_МЕНЯ_на_пароль_базы
POSTGRES_DB=dnd_portal

# Порт, на котором база видна с твоего компьютера.
# Оставь 127.0.0.1:5432 — тогда база доступна только локально, а не из сети.
# Если порт занят другим PostgreSQL, поменяй левое число, например на 5433.
DB_PORT=127.0.0.1:5432

# --- Первый администратор (создаётся при первом запуске) ---
# Логин необязателен (по умолчанию admin). Email и пароль ОБЯЗАТЕЛЬНЫ — без них
# контейнер не стартует. Пароль смени сразу после первого входа (страница «Профиль»).
ADMIN_USERNAME=admin
ADMIN_EMAIL=ЗАМЕНИ_МЕНЯ@example.com
ADMIN_PASSWORD=ЗАМЕНИ_МЕНЯ_на_пароль_админа
