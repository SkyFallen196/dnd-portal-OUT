# Настройки бэкенда для запуска БЕЗ Docker (нативно).
# Скопируй этот файл в .env и заполни значения:  cp .env.example .env
#
# Файл .env в git НЕ попадает (см. .gitignore) — в нём живут секреты.
# DATABASE_URL и JWT_SECRET ОБЯЗАТЕЛЬНЫ: без них приложение не запустится
# (специально — чтобы не работать с предсказуемым ключом или паролем из кода).
#
# В Docker эти же значения приходят из корневого .env — здесь заполнять не нужно.

# --- Обязательно ---

# Строка подключения к PostgreSQL (внутри неё пароль базы).
# Формат: postgresql+psycopg2://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:ПОРТ/ИМЯ_БД
# Пароль должен совпадать с тем, что задан для контейнера БД (POSTGRES_PASSWORD в корневом .env).
DATABASE_URL=postgresql+psycopg2://dnd:ЗАМЕНИ_МЕНЯ_на_пароль_базы@localhost:5432/dnd_portal

# Ключ подписи токенов входа. Замени на длинную случайную строку:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=ЗАМЕНИ_МЕНЯ_на_длинную_случайную_строку

# Данные первого администратора для seed_admin.py.
# ADMIN_EMAIL и ADMIN_PASSWORD ОБЯЗАТЕЛЬНЫ — без них seed_admin.py не создаст админа.
# Пароль смени сразу после первого входа (страница «Профиль»).
ADMIN_USERNAME=admin
ADMIN_EMAIL=ЗАМЕНИ_МЕНЯ@example.com
ADMIN_PASSWORD=ЗАМЕНИ_МЕНЯ_на_пароль_админа

# --- Необязательно (у этих полей есть значения по умолчанию) ---

# Сколько минут живёт токен входа (по умолчанию 7 дней).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Разрешённый источник фронтенда (CORS).
FRONTEND_ORIGIN=http://localhost:5173
